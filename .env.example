# ==========================================
# Cybabot Ultra - Environment Variables
# ==========================================
# Copy this file to .env and fill in your values

# ─── Database ─────────────────────────────
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/cybabot"
DATABASE_URL_SYNC="postgresql://postgres:postgres@localhost:5432/cybabot"

# ─── JWT Authentication ───────────────────
JWT_SECRET_KEY="change-me-to-a-long-random-secret-key"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── Stripe (Credit Purchases) ─────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Multi-LLM Provider API Keys ──────────
# Groq (xAI) - Fast, low cost inference
GROQ_API_KEY="gsk_..."

# Anthropic (Claude) - Best for complex reasoning
ANTHROPIC_API_KEY="sk-ant-..."

# DeepSeek - Cost-effective reasoning
DEEPSEEK_API_KEY="sk-..."

# Google Gemini - Multimodal capabilities
GOOGLE_API_KEY="AIza..."

# Ollama - Local inference (uncomment if using local)
# OLLAMA_BASE_URL="http://localhost:11434"

# ─── LLM Defaults ─────────────────────────
DEFAULT_LLM_PROVIDER="groq"
DEFAULT_LLM_MODEL="llama-3.3-70b-versatile"

# ─── Credit System ─────────────────────────
# Credit costs per build type
CREDIT_COST_QUICK=25
CREDIT_COST_STANDARD=75
CREDIT_COST_FULL=150
FREE_CREDITS_INITIAL=500

# ─── Stripe Price IDs (Credit Packs) ───────
STRIPE_PRICE_STARTER="price_..."
STRIPE_PRICE_BUILDER="price_..."
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_ENTERPRISE="price_..."

# ─── Frontend ─────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:8000/api/v1"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── WebSocket ─────────────────────────────
WS_PING_INTERVAL=30
WS_PING_TIMEOUT=10

# ─── Backtester ───────────────────────────
DEFAULT_INITIAL_BALANCE=10000
DEFAULT_RISK_PER_TRADE_PCT=2.0
DEFAULT_STOP_LOSS_PIPS=30
DEFAULT_TAKE_PROFIT_PIPS=60

# ─── Monte Carlo ───────────────────────────
MONTE_CARLO_SIMULATIONS=1000
MONTE_CARLO_SEED=42

# ─── Data Storage ────────────────────────
DUKASCOPY_CACHE_DIR="./data/raw/bi5_cache"
DUCKDB_PATH="./data/raw/ticks.duckdb"

# ─── Dev Settings ─────────────────────────
CORS_ORIGINS="http://localhost:3000,http://localhost:8000"
LOG_LEVEL="INFO"
DEBUG=false

# ─── Admin ────────────────────────────────
ADMIN_EMAIL="admin@cybabot.ai"
